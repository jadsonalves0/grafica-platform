{
  "name": "grafica-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/run-next-build.cjs",
    "start": "next start",
    "lint": "next lint",
    "test:unit": "node --experimental-strip-types scripts/run-unit-tests.mjs",
    "test:integration": "node --experimental-transform-types --import ./scripts/register-path-aliases.mjs scripts/run-integration-tests.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "inventory:diagnose": "node scripts/inventory-diagnose.mjs",
    "inventory:backfill-fifo": "node scripts/inventory-backfill-fifo.mjs",
    "prisma:apply-manual": "node scripts/apply-prisma-migration.mjs",
    "prisma:generate": "powershell -ExecutionPolicy Bypass -File scripts/run-prisma-generate.ps1",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.mjs"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@playwright/test": "^1.51.1",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "prisma": "^6.9.0",
    "typescript": "^5.8.3"
  }
}

model InventoryEntry {
  id                     String               @id @default(uuid()) @db.Uuid
  companyId              String               @map("company_id") @db.Uuid
  supplierId             String?              @map("supplier_id") @db.Uuid
  entryType              InventoryEntryType   @map("entry_type")
  source                 String               @default("MANUAL") @db.VarChar(20)
  supplierName           String?              @map("supplier_name") @db.VarChar(200)
  supplierDocument       String?              @map("supplier_document") @db.VarChar(30)
  documentNumber         String               @map("document_number") @db.VarChar(80)
  documentSeries         String?              @map("document_series") @db.VarChar(20)
  accessKey              String?              @map("access_key") @db.VarChar(44)
  issuedAt               DateTime?            @map("issued_at")
  protocol               String?              @db.VarChar(80)
  entryDate              DateTime             @map("entry_date") @db.Date
  notes                  String?
  status                 InventoryEntryStatus @default(DRAFT)
  financialCondition     FinancialCondition   @default(NONE) @map("financial_condition")
  financialAccountId     String?              @map("financial_account_id") @db.Uuid
  installmentCount       Int                  @default(1) @map("installment_count")
  firstDueDate           DateTime?            @map("first_due_date") @db.Date
  subtotal               Decimal              @default(0) @db.Decimal(12, 2)
  totalAmount            Decimal              @default(0) @map("total_amount") @db.Decimal(12, 2)
  confirmedAt            DateTime?            @map("confirmed_at")
  confirmedByUserId      String?              @map("confirmed_by_user_id") @db.Uuid
  canceledAt             DateTime?            @map("canceled_at")
  canceledByUserId       String?              @map("canceled_by_user_id") @db.Uuid
  cancelReason           String?              @map("cancel_reason")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  company                Company              @relation(fields: [companyId], references: [id])
  supplier               Supplier?            @relation(fields: [supplierId], references: [id])
  financialAccount       FinancialAccount?    @relation(fields: [financialAccountId], references: [id])
  confirmedByUser        User?                @relation("inventory_entry_confirmed_by", fields: [confirmedByUserId], references: [id])
  canceledByUser         User?                @relation("inventory_entry_canceled_by", fields: [canceledByUserId], references: [id])
  items                  InventoryEntryItem[]
  stockMovements         StockMovement[]
  fifoLayers             StockLayer[]
  financialEntries       FinancialEntry[]
  attachments            OperationalDocumentAttachment[]

  @@unique([companyId, supplierName, entryType, documentNumber])
  @@unique([companyId, accessKey])
  @@index([companyId, supplierId, entryDate])
  @@index([companyId, status, entryDate])
  @@map("inventory_entries")
}

model InventoryEntryItem {

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELED
}

enum UserStatus {
  ACTIVE
  INVITED
  BLOCKED
}

enum AuthTokenType {
  PASSWORD_RESET
  USER_INVITE
}

enum ProductCategoryType {
  RAW_MATERIAL
  SERVICE
  FINISHED_PRODUCT
}

enum ProductType {
  RAW_MATERIAL
  SERVICE
  FINISHED_PRODUCT
  RESALE
}

enum ProductValueChangeType {
  COST
  PRICE
}

enum StockMovementType {
  INPUT
  OUTPUT
  ADJUSTMENT
}

enum StockReferenceType {
  MANUAL
  QUOTE
  ORDER
  PURCHASE
  ENTRY
  PRODUCTION
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
}

enum OrderStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum ProductionStatus {
  PENDING
  IN_PRODUCTION
  WAITING_APPROVAL
  READY
  DELIVERED
}

enum FinancialAccountType {
  CASH
  BANK
  DIGITAL_WALLET
}

enum FinancialEntryType {
  INCOME
  EXPENSE
  RECEIVABLE
  PAYABLE
  TRANSFER
}

enum FinancialEntryStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
}

enum StockMovementReasonCode {
  ENTRY_CONFIRMATION
  ENTRY_REVERSAL
  PRODUCTION_CONSUMPTION
  PRODUCTION_OUTPUT
  PRODUCTION_REVERSAL
  ADJUSTMENT_POSITIVE
  ADJUSTMENT_NEGATIVE
  LOSS
  DAMAGE
  INTERNAL_CONSUMPTION
  SAMPLE
  DIVERSE_INPUT
  DIVERSE_OUTPUT
  INITIAL_BALANCE
  BONUS
  RETURN
}

enum StockMovementStatus {
  CONFIRMED
  REVERSED
}

enum InventoryEntryType {
  PURCHASE_INVOICE
  PURCHASE_WITHOUT_INVOICE
  INITIAL_BALANCE
  RETURN
  BONUS
  OTHER
}

enum InventoryEntryStatus {
  DRAFT
  CONFIRMED
  CANCELED
}

enum FinancialCondition {
  NONE
  CASH
  TERM
}

enum FinancialOriginType {
  MANUAL
  ENTRY
  PRODUCTION
  ORDER
  QUOTE
  WEBSITE
}

enum ProductionExecutionStatus {
  PENDING
  IN_PRODUCTION
  COMPLETED
  CANCELED
}

enum AuditAction {
  CREATE
  UPDATE
  CONFIRM
  CANCEL
  REVERSE
  OVERRIDE
}

enum SiteLeadStatus {
  NEW
  CONTACTED
  CONVERTED
  ARCHIVED
}

model Company {
  id              String               @id @default(uuid()) @db.Uuid
  legalName       String               @map("legal_name") @db.VarChar(200)
  tradeName       String               @map("trade_name") @db.VarChar(200)
  slug            String               @unique @db.VarChar(120)
  document        String?              @db.VarChar(30)
  email           String?              @db.VarChar(200)
  phone           String?              @db.VarChar(30)
  whatsapp        String?              @db.VarChar(30)
  status          CompanyStatus        @default(ACTIVE)
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  companyUsers    CompanyUser[]
  customers       Customer[]
  financials      FinancialEntry[]
  orders          Order[]
  productCategories ProductCategory[]
  productPriceHistories ProductPriceHistory[]
  products        Product[]
  productRecipeItems ProductRecipeItem[]
  productionRecords ProductionRecord[]
  quotes          Quote[]
  quoteItems      QuoteItem[]
  roles           Role[]
  siteBanners     SiteBanner[]
  siteLeads       SiteLead[]
  sitePages       SitePage[]
  siteServices    SiteService[]
  siteSettings    SiteSetting?
  stockMovements  StockMovement[]
  financialAccounts FinancialAccount[]
  financialCategories FinancialCategory[]
  orderItems      OrderItem[]
  supplierItemMappings SupplierItemMapping[]
  suppliers       Supplier[]
  operationalDocumentAttachments OperationalDocumentAttachment[]
  authSessions    AuthSession[]
  operationalSettings CompanyOperationalSetting?
  inventoryEntries InventoryEntry[]
  stockLayers     StockLayer[]
  stockLayerConsumptions StockLayerConsumption[]
  auditLogs       AuditLog[]

  @@map("companies")
}

model Supplier {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  legalName        String    @map("legal_name") @db.VarChar(200)
  tradeName        String?   @map("trade_name") @db.VarChar(200)
  document         String?   @db.VarChar(30)
  email            String?   @db.VarChar(200)
  phone            String?   @db.VarChar(30)
  whatsapp         String?   @db.VarChar(30)
  contactName      String?   @map("contact_name") @db.VarChar(200)
  addressZipCode   String?   @map("address_zip_code") @db.VarChar(20)
  addressStreet    String?   @map("address_street") @db.VarChar(200)
  addressNumber    String?   @map("address_number") @db.VarChar(20)
  addressDistrict  String?   @map("address_district") @db.VarChar(120)
  addressCity      String?   @map("address_city") @db.VarChar(120)
  addressState     String?   @map("address_state") @db.VarChar(80)
  notes            String?
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  company          Company   @relation(fields: [companyId], references: [id])
  inventoryEntries InventoryEntry[]
  supplierItemMappings SupplierItemMapping[]

  @@unique([companyId, document])
  @@index([companyId, isActive, legalName])
  @@index([companyId, tradeName])
  @@map("suppliers")
}

model User {
  id                   String              @id @default(uuid()) @db.Uuid
  name                 String              @db.VarChar(200)
  email                String              @unique @db.VarChar(200)
  passwordHash         String              @map("password_hash") @db.VarChar(255)
  phone                String?             @db.VarChar(30)
  isPlatformAdmin      Boolean             @default(false) @map("is_platform_admin")
  status               UserStatus          @default(ACTIVE)
  lastLoginAt          DateTime?           @map("last_login_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  approvedQuotes       Quote[]             @relation("approved_quotes")
  companyUsers         CompanyUser[]
  createdFinancials    FinancialEntry[]
  createdOrders        Order[]
  createdQuotes        Quote[]             @relation("created_quotes")
  createdStockMoves    StockMovement[] @relation("stock_movement_created_by")
  productPriceHistories ProductPriceHistory[]
  productionRecords    ProductionRecord[] @relation("production_produced_by_user")
  authSessions         AuthSession[]
  authTokens           AuthToken[]
  confirmedInventoryEntries InventoryEntry[] @relation("inventory_entry_confirmed_by")
  canceledInventoryEntries  InventoryEntry[] @relation("inventory_entry_canceled_by")
  reversedStockMovements    StockMovement[] @relation("stock_movement_reversed_by")
  responsibleProductions    ProductionRecord[] @relation("production_responsible_user")
  createdSupplierItemMappings SupplierItemMapping[] @relation("supplier_item_mapping_created_by")
  updatedSupplierItemMappings SupplierItemMapping[] @relation("supplier_item_mapping_updated_by")
  createdOperationalDocumentAttachments OperationalDocumentAttachment[] @relation("operational_document_attachment_created_by")
  auditLogs                 AuditLog[]

  @@map("users")
}

model CompanyUser {
  id          String            @id @default(uuid()) @db.Uuid
  companyId   String            @map("company_id") @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  company     Company           @relation(fields: [companyId], references: [id])
  user        User              @relation(fields: [userId], references: [id])
  userRoles   CompanyUserRole[]

  @@unique([companyId, userId])
  @@map("company_users")
}

model Role {
  id               String            @id @default(uuid()) @db.Uuid
  companyId        String?           @map("company_id") @db.Uuid
  name             String            @db.VarChar(120)
  code             String            @db.VarChar(120)
  isSystem         Boolean           @default(false) @map("is_system")
  createdAt        DateTime          @default(now()) @map("created_at")
  company          Company?          @relation(fields: [companyId], references: [id])
  rolePermissions  RolePermission[]
  userRoles        CompanyUserRole[]

  @@unique([companyId, code])
  @@map("roles")
}

model Permission {
  id               String            @id @default(uuid()) @db.Uuid
  module           String            @db.VarChar(80)
  action           String            @db.VarChar(80)
  code             String            @unique @db.VarChar(120)
  description      String?           @db.VarChar(255)
  rolePermissions  RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id            String       @id @default(uuid()) @db.Uuid
  roleId        String       @map("role_id") @db.Uuid
  permissionId  String       @map("permission_id") @db.Uuid
  role          Role         @relation(fields: [roleId], references: [id])
  permission    Permission   @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model CompanyUserRole {
  id             String        @id @default(uuid()) @db.Uuid
  companyUserId  String        @map("company_user_id") @db.Uuid
  roleId         String        @map("role_id") @db.Uuid
  companyUser    CompanyUser   @relation(fields: [companyUserId], references: [id])
  role           Role          @relation(fields: [roleId], references: [id])

  @@unique([companyUserId, roleId])
  @@map("company_user_roles")
}

model Customer {
  id              String      @id @default(uuid()) @db.Uuid
  companyId       String      @map("company_id") @db.Uuid
  name            String      @db.VarChar(200)
  document        String?     @db.VarChar(30)
  email           String?     @db.VarChar(200)
  phone           String?     @db.VarChar(30)
  whatsapp        String?     @db.VarChar(30)
  isActive        Boolean     @default(true) @map("is_active")
  addressZipCode  String?     @map("address_zip_code") @db.VarChar(20)
  addressStreet   String?     @map("address_street") @db.VarChar(200)
  addressNumber   String?     @map("address_number") @db.VarChar(20)
  addressDistrict String?     @map("address_district") @db.VarChar(120)
  addressCity     String?     @map("address_city") @db.VarChar(120)
  addressState    String?     @map("address_state") @db.VarChar(80)
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  company         Company     @relation(fields: [companyId], references: [id])
  financials      FinancialEntry[]
  orders          Order[]
  quotes          Quote[]

  @@unique([companyId, email])
  @@unique([companyId, document])
  @@map("customers")
}

model ProductCategory {
  id         String                @id @default(uuid()) @db.Uuid
  companyId  String                @map("company_id") @db.Uuid
  name       String                @db.VarChar(120)
  description String?
  type       ProductCategoryType?
  defaultMargin Decimal?           @map("default_margin") @db.Decimal(5, 2)
  showOnWebsite Boolean            @default(false) @map("show_on_website")
  isActive   Boolean               @default(true) @map("is_active")
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")
  company    Company               @relation(fields: [companyId], references: [id])
  products   Product[]

  @@unique([companyId, name])
  @@map("product_categories")
}

model Product {
  id            String            @id @default(uuid()) @db.Uuid
  companyId     String            @map("company_id") @db.Uuid
  categoryId    String?           @map("category_id") @db.Uuid
  name          String            @db.VarChar(200)
  sku           String?           @db.VarChar(80)
  barcode       String?           @db.VarChar(14)
  unit          String            @db.VarChar(20)
  type          ProductType
  controlsStock Boolean           @default(true) @map("controls_stock")
  showOnWebsite Boolean           @default(false) @map("show_on_website")
  desiredMargin Decimal?          @map("desired_margin") @db.Decimal(5, 2)
  costPrice     Decimal           @default(0) @map("cost_price") @db.Decimal(12, 2)
  salePrice     Decimal           @default(0) @map("sale_price") @db.Decimal(12, 2)
  minimumStock  Decimal           @default(0) @map("minimum_stock") @db.Decimal(12, 3)
  currentStock  Decimal           @default(0) @map("current_stock") @db.Decimal(12, 3)
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  category      ProductCategory?  @relation(fields: [categoryId], references: [id])
  company       Company           @relation(fields: [companyId], references: [id])
  financialEntryItems FinancialEntryItem[]
  orderItems    OrderItem[]
  priceHistories ProductPriceHistory[]
  recipeItems   ProductRecipeItem[] @relation("recipe_product")
  quoteItems    QuoteItem[]
  stockMoves    StockMovement[]
  inventoryEntryItems InventoryEntryItem[]
  stockLayers    StockLayer[]
  stockLayerConsumptions StockLayerConsumption[]
  supplierMappings SupplierItemMapping[]
  usedAsMaterialIn ProductRecipeItem[] @relation("recipe_material")
  productionRecords ProductionRecord[]
  productionConsumptions ProductionConsumption[]

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId, categoryId])
  @@map("products")
}

model ProductPriceHistory {
  id               String                 @id @default(uuid()) @db.Uuid
  companyId        String                 @map("company_id") @db.Uuid
  productId        String                 @map("product_id") @db.Uuid
  changedByUserId  String?                @map("changed_by_user_id") @db.Uuid
  changeType       ProductValueChangeType @map("change_type")
  previousValue    Decimal                @map("previous_value") @db.Decimal(12, 2)
  newValue         Decimal                @map("new_value") @db.Decimal(12, 2)
  origin           String                 @db.VarChar(80)
  relatedDocument  String?                @map("related_document") @db.VarChar(120)
  justification    String?
  createdAt        DateTime               @default(now()) @map("created_at")
  changedByUser    User?                  @relation(fields: [changedByUserId], references: [id])
  company          Company                @relation(fields: [companyId], references: [id])
  product          Product                @relation(fields: [productId], references: [id])

  @@index([companyId, productId, createdAt])
  @@map("product_price_histories")
}

model StockMovement {
  id              String              @id @default(uuid()) @db.Uuid
  companyId       String              @map("company_id") @db.Uuid
  productId       String              @map("product_id") @db.Uuid
  movementType    StockMovementType   @map("movement_type")
  status          StockMovementStatus @default(CONFIRMED)
  reasonCode      StockMovementReasonCode? @map("reason_code")
  reasonText      String?             @map("reason_text") @db.VarChar(255)
  quantity        Decimal             @db.Decimal(12, 3)
  unitCost        Decimal?            @map("unit_cost") @db.Decimal(12, 2)
  referenceType   StockReferenceType? @map("reference_type")
  referenceId     String?             @map("reference_id") @db.VarChar(80)
  inventoryEntryId String?            @map("inventory_entry_id") @db.Uuid
  productionRecordId String?          @map("production_record_id") @db.Uuid
  notes           String?
  createdByUserId String?             @map("created_by_user_id") @db.Uuid
  reversedByUserId String?            @map("reversed_by_user_id") @db.Uuid
  occurredAt      DateTime            @default(now()) @map("occurred_at")
  reversedAt      DateTime?           @map("reversed_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  company         Company             @relation(fields: [companyId], references: [id])
  createdByUser   User?               @relation("stock_movement_created_by", fields: [createdByUserId], references: [id])
  product         Product             @relation(fields: [productId], references: [id])
  reversedByUser  User?               @relation("stock_movement_reversed_by", fields: [reversedByUserId], references: [id])
  inventoryEntry  InventoryEntry?     @relation(fields: [inventoryEntryId], references: [id])
  productionRecord ProductionRecord?  @relation(fields: [productionRecordId], references: [id])
  fifoLayer       StockLayer?
  fifoConsumptions StockLayerConsumption[]

  @@index([companyId, productId, occurredAt])
  @@map("stock_movements")
}

model Quote {
  id               String        @id @default(uuid()) @db.Uuid
  companyId        String        @map("company_id") @db.Uuid
  customerId       String        @map("customer_id") @db.Uuid
  code             String        @db.VarChar(60)
  status           QuoteStatus   @default(DRAFT)
  issueDate        DateTime      @map("issue_date") @db.Date
  validUntil       DateTime?     @map("valid_until") @db.Date
  subtotal         Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount   Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount      Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  notes            String?
  createdByUserId  String?       @map("created_by_user_id") @db.Uuid
  approvedByUserId String?       @map("approved_by_user_id") @db.Uuid
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  approvedByUser   User?         @relation("approved_quotes", fields: [approvedByUserId], references: [id])
  company          Company       @relation(fields: [companyId], references: [id])
  createdByUser    User?         @relation("created_quotes", fields: [createdByUserId], references: [id])
  customer         Customer      @relation(fields: [customerId], references: [id])
  financials       FinancialEntry[]
  items            QuoteItem[]
  orders           Order[]

  @@unique([companyId, code])
  @@map("quotes")
}

model QuoteItem {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  quoteId     String    @map("quote_id") @db.Uuid
  productId   String?   @map("product_id") @db.Uuid
  description String    @db.VarChar(255)
  quantity    Decimal   @db.Decimal(12, 3)
  unitPrice   Decimal   @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal   @map("total_price") @db.Decimal(12, 2)
  company     Company   @relation(fields: [companyId], references: [id])
  product     Product?  @relation(fields: [productId], references: [id])
  quote       Quote     @relation(fields: [quoteId], references: [id])

  @@map("quote_items")
}

model Order {
  id               String            @id @default(uuid()) @db.Uuid
  companyId        String            @map("company_id") @db.Uuid
  customerId       String            @map("customer_id") @db.Uuid
  quoteId          String?           @map("quote_id") @db.Uuid
  code             String            @db.VarChar(60)
  status           OrderStatus       @default(OPEN)
  productionStatus ProductionStatus  @default(PENDING) @map("production_status")
  deliveryDate     DateTime?         @map("delivery_date") @db.Date
  totalAmount      Decimal           @default(0) @map("total_amount") @db.Decimal(12, 2)
  notes            String?
  createdByUserId  String?           @map("created_by_user_id") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  company          Company           @relation(fields: [companyId], references: [id])
  createdByUser    User?             @relation(fields: [createdByUserId], references: [id])
  customer         Customer          @relation(fields: [customerId], references: [id])
  financials       FinancialEntry[]
  items            OrderItem[]
  productionRecords ProductionRecord[]
  quote            Quote?            @relation(fields: [quoteId], references: [id])

  @@unique([companyId, code])
  @@map("orders")
}

model OrderItem {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  orderId     String    @map("order_id") @db.Uuid
  productId   String?   @map("product_id") @db.Uuid
  description String    @db.VarChar(255)
  quantity    Decimal   @db.Decimal(12, 3)
  unitPrice   Decimal   @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal   @map("total_price") @db.Decimal(12, 2)
  company     Company   @relation(fields: [companyId], references: [id])
  order       Order     @relation(fields: [orderId], references: [id])
  product     Product?  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model FinancialAccount {
  id             String                @id @default(uuid()) @db.Uuid
  companyId      String                @map("company_id") @db.Uuid
  name           String                @db.VarChar(120)
  type           FinancialAccountType
  initialBalance Decimal               @default(0) @map("initial_balance") @db.Decimal(12, 2)
  isActive       Boolean               @default(true) @map("is_active")
  createdAt      DateTime              @default(now()) @map("created_at")
  company        Company               @relation(fields: [companyId], references: [id])
  entries        FinancialEntry[]
  inventoryEntries InventoryEntry[]

  @@map("financial_accounts")
}

model FinancialCategory {
  id         String             @id @default(uuid()) @db.Uuid
  companyId  String             @map("company_id") @db.Uuid
  name       String             @db.VarChar(120)
  type       FinancialEntryType @map("entry_type")
  isActive   Boolean            @default(true) @map("is_active")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")
  company    Company            @relation(fields: [companyId], references: [id])
  entries    FinancialEntry[]

  @@unique([companyId, type, name])
  @@map("financial_categories")
}

model FinancialEntry {
  id              String                @id @default(uuid()) @db.Uuid
  companyId       String                @map("company_id") @db.Uuid
  accountId       String                @map("account_id") @db.Uuid
  financialCategoryId String?          @map("financial_category_id") @db.Uuid
  customerId      String?               @map("customer_id") @db.Uuid
  inventoryEntryId String?              @map("inventory_entry_id") @db.Uuid
  orderId         String?               @map("order_id") @db.Uuid
  quoteId         String?               @map("quote_id") @db.Uuid
  entryType       FinancialEntryType    @map("entry_type")
  originType      FinancialOriginType   @default(MANUAL) @map("origin_type")
  category        String                @db.VarChar(80)
  supplierName    String?               @map("supplier_name") @db.VarChar(200)
  description     String                @db.VarChar(255)
  amount          Decimal               @db.Decimal(12, 2)
  dueDate         DateTime              @map("due_date") @db.Date
  paidAt          DateTime?             @map("paid_at")
  installmentNumber Int?                @map("installment_number")
  installmentCount Int?                 @map("installment_count")
  canceledAt      DateTime?             @map("canceled_at")
  status          FinancialEntryStatus  @default(PENDING)
  createdByUserId String?               @map("created_by_user_id") @db.Uuid
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  account         FinancialAccount      @relation(fields: [accountId], references: [id])
  company         Company               @relation(fields: [companyId], references: [id])
  createdByUser   User?                 @relation(fields: [createdByUserId], references: [id])
  customer        Customer?             @relation(fields: [customerId], references: [id])
  financialCategory FinancialCategory?  @relation(fields: [financialCategoryId], references: [id])
  inventoryEntry  InventoryEntry?       @relation(fields: [inventoryEntryId], references: [id])
  items           FinancialEntryItem[]
  order           Order?                @relation(fields: [orderId], references: [id])
  quote           Quote?                @relation(fields: [quoteId], references: [id])

  @@index([companyId, entryType, status, dueDate])
  @@map("financial_entries")
}

model FinancialEntryItem {
  id          String          @id @default(uuid()) @db.Uuid
  entryId     String          @map("entry_id") @db.Uuid
  productId   String?         @map("product_id") @db.Uuid
  description String          @db.VarChar(255)
  quantity    Decimal         @db.Decimal(12, 3)
  unitPrice   Decimal         @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal         @map("total_price") @db.Decimal(12, 2)
  entry       FinancialEntry  @relation(fields: [entryId], references: [id])
  product     Product?        @relation(fields: [productId], references: [id])

  @@map("financial_entry_items")
}

model ProductRecipeItem {
  id                String    @id @default(uuid()) @db.Uuid
  companyId         String    @map("company_id") @db.Uuid
  productId         String    @map("product_id") @db.Uuid
  materialProductId String    @map("material_product_id") @db.Uuid
  quantityPerUnit   Decimal   @map("quantity_per_unit") @db.Decimal(12, 4)
  lossPercent       Decimal   @default(0) @map("loss_percent") @db.Decimal(5, 2)
